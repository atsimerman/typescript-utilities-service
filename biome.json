{
	"$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
	"root": true,
	"files": {
		"includes": [
			"**",
			"!**/*.css",
			"!src/components/ui/**/*",
			"!migrations/**/*"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"indentStyle": "tab",
		"indentWidth": 2
	}
}
